# 创建 .gitignore
cat > .gitignore << 'EOF'
# 必须忽略的三大缓存文件夹
Intermediate/
Saved/
DerivedDataCache/

# 忽略编译生成文件
Binaries/
Build/
.vs/

# 忽略IDE配置
*.sln
*.suo
*.opendb
*.user

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略 UE 生成的临时文件
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.sln.docstates

# 忽略自动保存和备份
*_BuiltData.uasset
*_Backup.uasset
*_Diff.uasset
